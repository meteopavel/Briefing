[Unit]
Description=Briefing — personal ops center
After=network.target

[Service]
Type=simple
User=YOUR_USER
WorkingDirectory=/home/YOUR_USER/apps/briefing
ExecStart=/home/YOUR_USER/apps/briefing/.venv/bin/uvicorn app.web:app --host 127.0.0.1 --port 8001
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
